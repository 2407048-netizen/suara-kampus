# ============================================================
# SUARA KAMPUS - Environment Variables
# Copy file ini menjadi .env.local dan isi nilainya
# ============================================================

# JWT Secret (wajib, gunakan string panjang & random)
JWT_SECRET_KEY=your_super_secret_jwt_key_here_minimum_32_chars

# URL aplikasi (wajib untuk email verification links)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ---- SMTP Email Configuration ----
# Gunakan Gmail App Password (bukan password biasa!)
# Cara buat App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-2407048@itg.ac.id
SMTP_PASS=your-twslcssaoykiveas

# ---- Pusher (Opsional - untuk Live Chat) ----
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
