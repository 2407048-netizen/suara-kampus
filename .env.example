# ============================================================
# Suara Kampus ITG - Environment Variables
# Salin file ini ke .env.local untuk pengembangan lokal
# Daftarkan semua variabel ini di Vercel Settings > Environment Variables
# ============================================================

# ── DATABASE (Turso) ─────────────────────────────────────────
# Dapatkan dari: https://turso.tech → Dashboard → Database → Connect
TURSO_DATABASE_URL=libsql://nama-database-anda.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSJ9...

# ── AUTHENTICATION ────────────────────────────────────────────
# Buat string acak minimal 32 karakter. Contoh: openssl rand -base64 32
JWT_SECRET_KEY=ganti_dengan_string_rahasia_minimal_32_karakter

# ── APPLICATION URL ───────────────────────────────────────────
# URL aplikasi Anda (tanpa trailing slash)
NEXT_PUBLIC_APP_URL=https://suara-kampus-orcin.vercel.app

# ── SMTP EMAIL (Kampus ITG) ───────────────────────────────────
# Konfigurasi SMTP kampus ITG untuk pengiriman OTP
SMTP_HOST=mail.itg.ac.id
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=email_anda@itg.ac.id
SMTP_PASS=password_email_anda
SMTP_FROM=Suara Kampus ITG <noreply@itg.ac.id>

# ── VERCEL BLOB STORAGE ───────────────────────────────────────
# Dapatkan dari: Vercel Dashboard → Storage → Blob → Connect Store
# WAJIB untuk fitur upload foto pengaduan dan bukti penyelesaian
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── PUSHER (Opsional - untuk fitur chat real-time) ────────────
# Jika tidak menggunakan Pusher, kosongkan. Fitur chat tetap berjalan tanpa real-time.
# Dapatkan dari: https://pusher.com → Dashboard → App Keys
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
